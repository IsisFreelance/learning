VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# The site's own public URL — used server-side (api/ routes) to build links
# in emails, instead of trusting the request's Host header. Not secret, but
# doesn't need a VITE_ prefix since only server code reads it. Set this in
# Vercel's dashboard for Production/Preview; not needed for local `npm run
# dev` since api/ routes never run locally in this project.
PUBLIC_BASE_URL=https://your-deployed-domain.vercel.app

# Stripe test-mode keys (server-only, never VITE_-prefixed — real secrets).
# STRIPE_SECRET_KEY comes straight from the Stripe dashboard (test mode).
# STRIPE_WEBHOOK_SECRET can only be generated after this code is deployed,
# since Stripe needs a real URL to register the webhook endpoint against.
STRIPE_SECRET_KEY=sk_test_your-stripe-test-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-signing-secret
