rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Matches the exact shape createBooking() writes in src/lib/bookings.js —
    // anything with extra/missing fields or wrong types is rejected outright,
    // so a script can't drop garbage or oversized spam into `bookings` even
    // though creation has to stay open to anonymous visitors.
    // "Signed in" is not the same as "staff" — a Firebase project can end
    // up with non-staff accounts (e.g. if self-serve sign-up is ever left
    // on), so anything staff-only must check the custom claim
    // (see scripts/set-staff-claim.js, api/_lib/staffAuth.js), not just
    // request.auth != null.
    function isStaff() {
      return request.auth != null && request.auth.token.staff == true;
    }

    function isValidBooking(data) {
      return data.keys().hasOnly([
        'services', 'totalMinutes', 'date', 'startTime', 'endTime',
        'name', 'email', 'phone', 'reference', 'status', 'createdAt', 'manageToken', 'notifiedAt',
        'depositStatus'
      ])
        && data.services is list && data.services.size() > 0
        && data.totalMinutes is number && data.totalMinutes > 0
        && data.date is string && data.date.size() > 0
        && data.startTime is string && data.startTime.size() > 0
        && data.endTime is string && data.endTime.size() > 0
        && data.name is string && data.name.size() > 0 && data.name.size() <= 200
        && data.email is string && data.email.size() > 0 && data.email.size() <= 200
        && data.phone is string && data.phone.size() > 0 && data.phone.size() <= 50
        && data.reference is string && data.reference.matches('BHD-.*')
        && data.status == 'Pending'
        && data.createdAt is timestamp
        // The "manage my booking" link's secret (see ManageBooking.jsx /
        // api/manage-booking.js) — always generated at creation time, never
        // readable by the public since `bookings` only allows read to staff.
        && data.manageToken is string && data.manageToken.size() > 0 && data.manageToken.size() <= 100
        // Set by api/notify-booking.js the first time it successfully
        // emails a booking, so a replayed call can't re-send or
        // double-book a calendar event. Optional at creation time.
        && (!('notifiedAt' in data) || data.notifiedAt is timestamp)
        // Set by the client at creation time ('unpaid') — api/create-checkout-session.js,
        // api/stripe-webhook.js and api/expire-unpaid-holds.js are the only
        // things that ever move it on from there.
        && data.depositStatus is string && data.depositStatus.size() > 0;
    }

    // Every field an update is allowed to touch, type-checked the same way
    // isValidBooking() checks creation — but each field is optional here
    // (an update only sends the fields it's changing), and there's no
    // "must equal exactly this" constraint like status == 'Pending', since
    // legitimate updates (confirm, cancel, reschedule, propose) all change
    // status or date/time on purpose.
    function isValidBookingUpdate(data) {
      return data.diff(resource.data).affectedKeys().hasOnly([
        'services', 'totalMinutes', 'date', 'startTime', 'endTime',
        'name', 'email', 'phone', 'reference', 'status', 'manageToken', 'notifiedAt',
        'proposedDate', 'proposedStartTime', 'proposedEndTime', 'googleCalendarEventId', 'confirmedByPatient',
        'depositStatus', 'depositAmountCents', 'stripeCheckoutSessionId', 'stripePaymentIntentId', 'depositPaidAt'
      ])
        && (!('services' in data) || (data.services is list && data.services.size() > 0))
        && (!('totalMinutes' in data) || (data.totalMinutes is number && data.totalMinutes > 0))
        && (!('date' in data) || (data.date is string && data.date.size() > 0))
        && (!('startTime' in data) || (data.startTime is string && data.startTime.size() > 0))
        && (!('endTime' in data) || (data.endTime is string && data.endTime.size() > 0))
        && (!('name' in data) || (data.name is string && data.name.size() > 0 && data.name.size() <= 200))
        && (!('email' in data) || (data.email is string && data.email.size() > 0 && data.email.size() <= 200))
        && (!('phone' in data) || (data.phone is string && data.phone.size() > 0 && data.phone.size() <= 50))
        && (!('reference' in data) || (data.reference is string && data.reference.matches('BHD-.*')))
        && (!('status' in data) || (data.status is string && data.status.size() > 0))
        && (!('manageToken' in data) || (data.manageToken is string && data.manageToken.size() > 0 && data.manageToken.size() <= 100))
        && (!('notifiedAt' in data) || data.notifiedAt is timestamp)
        && (!('proposedDate' in data) || (data.proposedDate is string && data.proposedDate.size() > 0))
        && (!('proposedStartTime' in data) || (data.proposedStartTime is string && data.proposedStartTime.size() > 0))
        && (!('proposedEndTime' in data) || (data.proposedEndTime is string && data.proposedEndTime.size() > 0))
        && (!('googleCalendarEventId' in data) || data.googleCalendarEventId == null || data.googleCalendarEventId is string)
        && (!('confirmedByPatient' in data) || data.confirmedByPatient is bool)
        && (!('depositStatus' in data) || (data.depositStatus is string && data.depositStatus.size() > 0))
        && (!('depositAmountCents' in data) || (data.depositAmountCents is number && data.depositAmountCents > 0))
        && (!('stripeCheckoutSessionId' in data) || (data.stripeCheckoutSessionId is string && data.stripeCheckoutSessionId.size() > 0))
        && (!('stripePaymentIntentId' in data) || (data.stripePaymentIntentId is string && data.stripePaymentIntentId.size() > 0))
        && (!('depositPaidAt' in data) || data.depositPaidAt is timestamp);
    }

    function isValidBookingSlot(data) {
      return data.keys().hasOnly(['date', 'time', 'bookingId'])
        && data.date is string && data.date.size() > 0
        && data.time is string && data.time.size() > 0
        && data.bookingId is string && data.bookingId.size() > 0;
    }

    // `count` may only start at 1 and climb by exactly 1 per write, so no one
    // can jump the sequence, rewind it, or write a non-numeric value —
    // deleting the counter isn't allowed either, since that would silently
    // reset every future booking's reference number back to BHD-000001.
    function isValidCounterFields(data) {
      return data.keys().hasOnly(['count']) && data.count is int && data.count > 0;
    }

    match /bookings/{bookingId} {
      allow create: if isValidBooking(request.resource.data);
      allow read, delete: if isStaff();
      allow update: if isStaff() && isValidBookingUpdate(request.resource.data);
    }
    match /bookingSlots/{slotId} {
      allow read: if true;
      allow create: if isValidBookingSlot(request.resource.data);
      allow update: if false;
      allow delete: if isStaff();
    }
    match /counters/{counterId} {
      allow read: if true;
      allow create: if isValidCounterFields(request.resource.data)
        && request.resource.data.count == 1;
      allow update: if isValidCounterFields(request.resource.data)
        && request.resource.data.count == resource.data.count + 1;
    }
  }
}
