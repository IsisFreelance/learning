DATABASE_URL=postgresql+psycopg://catalog_app:changeme@localhost:5432/catalog_intake
FRONTEND_ORIGIN=http://localhost:5173
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=intake-photos

# Phase 4 admin login — a single hardcoded password (no user table). Pick a
# real password locally and a different, stronger one on Render.
ADMIN_PASSWORD=changeme
# Random string used to sign session tokens issued at login — generate one
# with, e.g., `python -c "import secrets; print(secrets.token_hex(32))"`.
# Changing this instantly invalidates every existing session token.
SESSION_SECRET=changeme-generate-a-real-random-value

# Optional, LOCAL WINDOWS DEV ONLY — Tesseract isn't on PATH by default on
# Windows, so this points pytesseract at the exact binary. Never set this
# in a deployed environment (Render's Docker image puts tesseract on PATH
# itself) — accidentally copying this to Render is what broke the first
# Phase 2 deploy.
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
